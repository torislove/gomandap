# GoMandap Environment Variables Template
# DO NOT commit the actual .env file to version control.

# Backend (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Location (Mapbox)
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# Payments (Razorpay)
RAZORPAY_KEY=rzp_live_your_key

# Communication (WhatsApp & Email)
WHATSAPP_API_TOKEN=your-meta-whatsapp-token
RESEND_API_KEY=re_your_resend_key

# Public APIs (Optional Overrides)
PINCODE_API_URL=https://api.postalpincode.in
IFSC_API_URL=https://ifsc.razorpay.com
