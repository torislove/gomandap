rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Vendor Media ───────────────────────────────────────────────────
    match /vendors/{vendorId}/{allPaths=**} {
      // Public read (clients see vendor photos)
      allow read: if true;

      // Only the vendor who owns this profile can upload
      allow write: if request.auth != null
        && request.auth.uid == vendorId
        && request.resource.size < 50 * 1024 * 1024  // Max 50 MB per file
        && (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType.matches('video/.*')
        );

      // Admins can delete
      allow delete: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // ─── User Profile Photos ─────────────────────────────────────────────
    match /users/{userId}/profile/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024   // Max 5 MB
        && request.resource.contentType.matches('image/.*');
    }
  }
}
