<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Splash theme for pre-Android 12 fallback using the SplashScreen compat library.

        Usage:
        1. Set this theme on the launch activity in AndroidManifest.xml:
           android:theme="@style/Theme.Gomandap.Splash"

        2. In the activity's onCreate(), call SplashScreenSetup.install(this)
           BEFORE super.onCreate(). The compat library handles the theme switch
           to postSplashScreenTheme automatically.

        3. Define Theme.Gomandap in your app module's themes.xml as the main app theme.
    -->
    <style name="Theme.Gomandap.Splash" parent="Theme.SplashScreen">
        <!-- Royal Navy background (#0F172A) -->
        <item name="windowSplashScreenBackground">#0F172A</item>
        <!-- Centered GoMandap logo icon -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_gm_logo</item>
        <!-- Switch to main theme after splash -->
        <item name="postSplashScreenTheme">@style/Theme.Gomandap.Main</item>
    </style>

    <!-- Placeholder main theme - override in app module -->
    <style name="Theme.Gomandap.Main" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
